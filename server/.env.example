# ─── Server (Watcher) ────────────────────────────────────────────────
# WebSocket RPC for real-time block monitoring (Alchemy, Infura, etc.)
RPC_WSS=wss://sepolia.infura.io/ws/v3/YOUR_KEY

# ─── Bundler (Flashbots) ────────────────────────────────────────────
# JSON-RPC for Sepolia (bundle building, simulation, sending)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY

# Contract owner wallet private key (no 0x prefix)
PRIVATE_KEY=your_owner_private_key_here

# Flashbots relay signing key (no 0x prefix) — NOT your money key
# Generate with: node -e "console.log(require('ethers').Wallet.createRandom().privateKey)"
FLASHBOTS_AUTH_KEY=your_flashbots_auth_key_here

# ─── Token addresses (Sepolia) ──────────────────────────────────────
SEPOLIA_WETH=0x7b79995e5f793A07Bc00c21412e50Ecae098E7f9
SEPOLIA_USDC=0x94a9d9ac8a22534e3faca9f4e7f2e2cf85d5e4c8

# ─── Dashboard ──────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ─── Testing ────────────────────────────────────────────────────────
# Set to "true" to emit a mock liquidation signal on startup
MOCK_MODE=false
# Set to "true" to emit a mock arbitrage signal on startup
MOCK_ARB=false
# Set to "true" to emit a mock backrun signal on startup
MOCK_BACKRUN=false
